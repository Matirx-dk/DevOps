apiVersion: v1
kind: Secret
metadata:
  name: harbor-regcred
  namespace: jenkins
type: kubernetes.io/dockerconfigjson
data:
  .dockerconfigjson: <BASE64_DOCKER_CONFIG_JSON>

# 生成方式示例：
# kubectl -n jenkins create secret docker-registry harbor-regcred \
#   --docker-server=192.168.1.100:3443 \
#   --docker-username='<user>' \
#   --docker-password='<password>' \
#   --docker-email='devops@example.com' \
#   --dry-run=client -o yaml > deploy/k8s/jenkins-harbor-regcred.yaml
