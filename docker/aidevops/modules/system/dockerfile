# 基础镜像
FROM  openjdk:17
# author
MAINTAINER aidevops

# 挂载目录
VOLUME /home/aidevops
# 创建目录
RUN mkdir -p /home/aidevops
# 指定路径
WORKDIR /home/aidevops
# 复制jar文件到路径
COPY ./jar/aidevops-modules-system.jar /home/aidevops/aidevops-modules-system.jar
# 启动系统服务
ENTRYPOINT ["java","-jar","aidevops-modules-system.jar"]